    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.8",
    "@angular/cli": "^22.0.8",
    "@angular/compiler-cli": "^22.0.8",
    "angular-eslint": "21.4.0",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
